# Copy this file to .env and fill in real values.

# --- Core ---
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Leave DB_ENGINE unset or set to sqlite for quick local testing.
# Set DB_ENGINE=postgres to use PostgreSQL in production or when a server is available.
DB_ENGINE=sqlite
DB_NAME=study_ai_matcher
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- JWT ---
JWT_ACCESS_MIN=60
JWT_REFRESH_DAYS=7

# --- CORS (React dev server) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# --- Redis / Channels (WebSocket chat) ---
# Set USE_REDIS=True once you have Redis running (required in production).
USE_REDIS=False
REDIS_URL=redis://127.0.0.1:6379/0

# --- AI provider (Module 8: suggestions / chatbot / quiz) ---
# AI_PROVIDER must be "gemini" or "openai". Leave the matching key blank to
# run in offline/rule-based fallback mode (no billing, limited responses).
AI_PROVIDER=gemini
GEMINI_API_KEY=replace-with-your-gemini-key

